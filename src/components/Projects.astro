---
/**
 * PROJECTS — src/components/Projects.astro
 * ==========================================
 * 2x2 grid of project cards on the homepage.
 *
 * Content comes from src/data/projects.ts → `projects` array.
 * To add a new project: edit that file. No changes needed here.
 *
 * Card anatomy:
 *   - Screenshot preview (project.imageUrl) or gradient fallback (project.gradient)
 *   - Title + subtitle
 *   - Description paragraph
 *   - Tech stack badge pills
 *   - Action buttons (Case Study, Live Demo, Medium, GitHub)
 *     — only rendered when the corresponding URL is provided
 *
 * Cards with `hasCaseStudy: true` show a primary "Case Study →" button
 * that links to src/pages/projects/[slug].astro.
 *
 * Hover effect: card lifts slightly (-translate-y-1) and border brightens.
 */

import { projects } from '../data/projects';
---

<section id="work" class="py-24 px-6 border-t border-[#2d2d2f]">
  <div class="max-w-6xl mx-auto">

    <p class="reveal text-accent text-sm font-medium uppercase tracking-widest mb-4">Work</p>
    <h2 class="reveal text-4xl font-bold text-[#f5f5f7] mb-4">Featured Projects</h2>
    <p class="reveal text-[#6e6e73] mb-16 max-w-xl">
      Projects with a Case Study include architecture diagrams, data models, and the key
      engineering decisions behind them.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project, i) => (
        <div
          class="reveal glass-card rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 flex flex-col"
          style={`animation-delay:${i * 0.1}s`}
        >
          <!-- Card header: screenshot if available, otherwise gradient strip -->
          {project.imageUrl ? (
            <div class="h-48 overflow-hidden">
              <img
                src={project.imageUrl}
                alt={`${project.title} screenshot`}
                class="w-full h-full object-cover object-top"
              />
            </div>
          ) : (
            <div class={`h-48 bg-gradient-to-br ${project.gradient} flex items-center justify-center`}>
              <span class="text-white text-xl font-bold opacity-60">{project.title}</span>
            </div>
          )}

          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-[#f5f5f7] font-semibold text-lg mb-1">{project.title}</h3>
            <p class="text-accent text-xs font-medium mb-3">{project.subtitle}</p>
            <p class="text-[#6e6e73] text-sm leading-relaxed mb-4 flex-1">{project.description}</p>

            <!-- Tech stack badges -->
            <div class="flex flex-wrap gap-2 mb-5">
              {project.tags.map((tag) => <span class="badge">{tag}</span>)}
            </div>

            <!-- Action buttons — rendered conditionally based on what URLs exist -->
            <div class="flex flex-wrap gap-3">
              {project.hasCaseStudy && project.caseStudyUrl && (
                <a
                  href={project.caseStudyUrl}
                  class="bg-accent hover:bg-[#0077ed] text-white text-sm font-medium px-4 py-2 rounded-full transition-colors"
                >
                  Case Study →
                </a>
              )}
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  class="border border-[#2d2d2f] hover:border-[#6e6e73] text-[#a1a1a6] hover:text-[#f5f5f7] text-sm font-medium px-4 py-2 rounded-full transition-colors"
                >
                  Live Demo
                </a>
              )}
              {project.mediumUrl && (
                <a
                  href={project.mediumUrl}
                  target="_blank"
                  class="border border-[#2d2d2f] hover:border-[#6e6e73] text-[#a1a1a6] hover:text-[#f5f5f7] text-sm font-medium px-4 py-2 rounded-full transition-colors"
                >
                  Medium
                </a>
              )}
              {project.githubUrl && (
                <a
                  href={project.githubUrl}
                  target="_blank"
                  class="border border-[#2d2d2f] hover:border-[#6e6e73] text-[#a1a1a6] hover:text-[#f5f5f7] text-sm font-medium px-4 py-2 rounded-full transition-colors"
                >
                  GitHub
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
