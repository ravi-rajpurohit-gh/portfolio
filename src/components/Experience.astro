---
/**
 * EXPERIENCE — src/components/Experience.astro
 * ==============================================
 * Vertical timeline of work roles, with an education card at the bottom.
 *
 * Content comes from src/data/experience.ts:
 *   - roles[]     → work history entries (most recent first)
 *   - education[] → degree entries
 *
 * To add a new role or update an existing one: edit experience.ts only.
 * No changes needed in this file.
 *
 * Timeline anatomy:
 *   - Blue dot on the left for the current role (accent: true)
 *   - Gray dot for past roles
 *   - Connecting line between dots (hidden on the last entry)
 *   - Card with role title, company (in accent color), date badge, and bullets
 */

import { roles, education } from '../data/experience';
---

<section id="experience" class="py-24 px-6 border-t border-[#2d2d2f]">
  <div class="max-w-6xl mx-auto">

    <p class="reveal text-accent text-sm font-medium uppercase tracking-widest mb-4">Experience</p>
    <h2 class="reveal text-4xl font-bold text-[#f5f5f7] mb-16">Where I've Worked</h2>

    <div class="space-y-0">
      {roles.map((role, i) => (
        <div
          class="reveal relative pl-10 pb-12"
          style={`animation-delay:${i * 0.1}s`}
        >
          <!-- Timeline dot — blue for current role, gray for past -->
          <div
            class={`absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full border-2 ${
              role.accent
                ? 'bg-accent border-accent'
                : 'bg-[#2d2d2f] border-[#6e6e73]'
            }`}
          ></div>

          <!-- Connecting vertical line (hidden on last entry) -->
          {i < roles.length - 1 && (
            <div class="absolute left-[6px] top-5 bottom-0 w-px bg-[#2d2d2f]"></div>
          )}

          <!-- Role card -->
          <div class="glass-card rounded-2xl p-6 transition-colors">
            <div class="mb-3">
              <h3 class="text-[#f5f5f7] font-semibold text-lg">{role.title}</h3>
              <p class="text-accent text-sm font-medium mt-0.5">{role.company}</p>
            </div>

            <!-- Bullet points -->
            <ul class="space-y-2 list-disc list-inside mb-4">
              {role.bullets.map((bullet) => (
                <li class="text-sm text-[#a1a1a6] leading-relaxed marker:text-[#6e6e73]">
                  {bullet}
                </li>
              ))}
            </ul>

            {role.caseStudyUrl && (
              <a
                href={role.caseStudyUrl}
                class="inline-block bg-accent hover:bg-[#0077ed] text-white text-sm font-medium px-4 py-2 rounded-full transition-colors"
              >
                Case Study →
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Education — rendered from education[] in experience.ts -->
    {education.map((deg) => (
      <div class="reveal mt-2 glass-card rounded-2xl p-6">
        <p class="text-[#6e6e73] text-xs uppercase tracking-widest font-medium mb-3">Education</p>
        <div class="flex flex-wrap justify-between gap-2 mb-4">
          <div>
            <p class="text-[#f5f5f7] font-semibold">{deg.degree}</p>
            <p class="text-accent text-sm">{deg.school}</p>
          </div>
          <span class="text-[#6e6e73] text-sm">{deg.period}</span>
        </div>
        {deg.campusRoles && deg.campusRoles.length > 0 && (
          <div class="border-t border-white/[0.06] pt-4">
            <p class="text-[#6e6e73] text-xs uppercase tracking-widest font-medium mb-2">Also while there</p>
            <div class="flex flex-wrap gap-2">
              {deg.campusRoles.map((r) => (
                r.url
                  ? <a href={r.url} target="_blank" class="inline-block text-xs font-medium px-3 py-1 rounded-full border border-white/[0.08] text-[#a1a1a6] hover:text-accent hover:border-accent/40 transition-colors">{r.title} ↗</a>
                  : <span class="inline-block text-xs font-medium px-3 py-1 rounded-full border border-white/[0.08] text-[#a1a1a6]">{r.title}</span>
              ))}
            </div>
          </div>
        )}
      </div>
    ))}

  </div>
</section>
