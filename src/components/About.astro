---
/**
 * ABOUT — src/components/About.astro
 * =====================================
 * Two-column section: narrative text on the left, profile photo on the right.
 * Below the text: skill badges and a personal/fun note.
 *
 * Content comes from src/data/site.ts:
 *   - site.photo    → profile photo (update path in site.ts to switch formats)
 *   - site.skills   → badge list below the bio text
 *
 * TO UPDATE THE BIO TEXT: edit the <p> paragraphs in the template below.
 *   This is intentionally kept in the component (not in site.ts) because it's
 *   narrative prose that's unlikely to change structure, only content.
 *
 * The profile photo has a subtle blue glow ring (the div behind it).
 * Photo is circular via `rounded-full` and `object-cover`.
 * The `onerror` fallback switches to .jpg if .png fails to load.
 */

import { site } from '../data/site';
---

<section id="about" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <p class="reveal text-accent text-sm font-medium uppercase tracking-widest mb-4">About</p>

    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Left: text, skills, personal note -->
      <div>
        <h2 class="reveal text-4xl font-bold text-[#f5f5f7] mb-6 leading-tight">
          Building data systems<br />that actually get used.
        </h2>

        <!-- Bio paragraphs — edit these directly -->
        <div
          class="reveal space-y-4 text-[#a1a1a6] text-lg leading-relaxed"
          style="animation-delay:0.1s"
        >
          <p>
            I've spent the last several years
            building pipelines that process billions of events per month, cloud data platforms that
            cut executive reporting from days to under an hour, and data visualizations that make
            complex datasets worth looking at.
          </p>
          <p>
            Before my MS in Computer Science at UT Arlington, I built the data backbone for a
            wearable health platform at KaHa Technologies — Kafka ingestion, real-time telemetry,
            10M+ users. I'm most interested in the full picture: from how data gets ingested to
            whether the person reading the dashboard actually trusts what it shows.
          </p>
        </div>

        <!-- Skill badges — sourced from site.skills in site.ts -->
        <div class="reveal mt-8 flex flex-wrap gap-3" style="animation-delay:0.2s">
          {site.skills.map((skill) => <span class="badge">{skill}</span>)}
        </div>

        <!-- Personal note — edit the text and the chef link directly below -->
        <p class="reveal mt-8 text-[#6e6e73] text-sm" style="animation-delay:0.3s">
          ⚡ Outside of work: 🏸 racket sports, 🎸 music, 🧑‍🍳 cooking — and yes, I once{' '}
          <a
            href="https://drive.google.com/file/d/1VNMML9SCU_KENcqndlxAjtqMP5y43bFL/view?usp=sharing"
            target="_blank"
            class="text-accent hover:underline"
          >
            worked as a chef
          </a>{' '}
          for my university.
        </p>
      </div>

      <!-- Right: profile photo with glow effect -->
      <div class="reveal flex justify-center md:justify-end" style="animation-delay:0.15s">
        <div class="relative">
          <!-- Blue glow ring behind photo -->
          <div class="absolute inset-0 rounded-full bg-accent opacity-10 blur-2xl scale-110"></div>
          <!-- Photo — src and onerror fallback controlled by site.photo -->
          <img
            src={site.photo}
            alt="Ravi Rajpurohit"
            class="relative w-72 h-72 rounded-full object-cover border-2 border-[#2d2d2f]"
            onerror="this.src='/images/profile_pic.jpg'"
          />
        </div>
      </div>

    </div>
  </div>
</section>
