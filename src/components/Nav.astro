---
/**
 * NAV — src/components/Nav.astro
 * ================================
 * Sticky top navigation bar with blur-on-scroll effect.
 *
 * Content comes from src/data/site.ts:
 *   - site.navLinks  → the anchor links in the middle
 * The right-side CTA links to #contact.
 *
 * The nav starts transparent and gains a blurred dark background once the
 * user scrolls past 20px. This is handled by the inline <script> below.
 *
 * TO ADD A NEW NAV LINK: edit site.navLinks in src/data/site.ts.
 * TO CHANGE THE LOGO TEXT: edit the "RR" anchor below.
 */

import { site } from '../data/site';
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="text-[#f5f5f7] font-semibold text-lg tracking-tight hover:text-accent transition-colors">
      ꝚꝚ
    </a>

    <!-- Desktop links (hidden on mobile) -->
    <div class="hidden md:flex items-center gap-8">
      {site.navLinks.map((link) => (
        <a
          href={link.href}
          class="text-[#a1a1a6] hover:text-[#f5f5f7] text-sm font-medium transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Get in Touch CTA -->
    <a
      href="#contact"
      class="bg-accent hover:bg-[#0077ed] text-white text-sm font-medium px-4 py-2 rounded-full transition-colors duration-200"
    >
      Get in Touch
    </a>

  </div>
</nav>

<script>
  /**
   * Adds a blurred dark background to the nav when scrolled.
   * Runs immediately on load and on every scroll event.
   */
  const nav = document.getElementById('nav')!;

  function updateNav() {
    if (window.scrollY > 20) {
      nav.style.cssText =
        'background:rgba(0,0,0,0.45);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(255,255,255,0.08);';
    } else {
      nav.style.cssText =
        'background:rgba(0,0,0,0.1);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);';
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav(); // run once on initial load
</script>
