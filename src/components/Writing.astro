---
/**
 * WRITING — src/components/Writing.astro
 * ========================================
 * Grid of technical article cards linking to Medium.
 *
 * Content comes from src/data/articles.ts → `articles` array.
 * To add a new article: edit that file. No changes needed here.
 *
 * Card anatomy:
 *   - Gradient header strip with a category tag pill
 *   - Article title (highlights in accent blue on hover)
 *   - Summary text
 *   - Date, read time, and "Read →" link
 *
 * The "All articles on Medium →" link at the bottom uses site.social.medium.
 */

import { articles } from '../data/articles';
import { site } from '../data/site';
---

<section id="writing" class="py-24 px-6 border-t border-[#2d2d2f]">
  <div class="max-w-6xl mx-auto">

    <p class="reveal text-accent text-sm font-medium uppercase tracking-widest mb-4">Writing</p>
    <h2 class="reveal text-4xl font-bold text-[#f5f5f7] mb-4">Technical Writing</h2>
    <p class="reveal text-[#6e6e73] mb-16 max-w-xl">
      I write about data engineering patterns, visualization architecture, and lessons from
      building real systems.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {articles.map((article, i) => (
        <a
          href={article.url}
          target="_blank"
          class="reveal block glass-card rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 group"
          style={`animation-delay:${i * 0.1}s`}
        >
          <!-- Gradient header with category tag -->
          <div class={`h-28 bg-gradient-to-br ${article.gradient} flex items-end p-4`}>
            <span class="text-white/80 text-xs font-medium bg-black/30 px-2 py-1 rounded-full">
              {article.tag}
            </span>
          </div>

          <div class="p-6">
            <!-- Title highlights in accent on hover via the `group` class -->
            <h3 class="text-[#f5f5f7] font-semibold text-base leading-snug mb-3 group-hover:text-accent transition-colors">
              {article.title}
            </h3>
            <p class="text-[#6e6e73] text-sm leading-relaxed mb-4">{article.summary}</p>

            <div class="flex items-center justify-between">
              <div class="flex gap-3 text-xs text-[#6e6e73]">
                <span>{article.date}</span>
                <span>·</span>
                <span>{article.readTime}</span>
              </div>
              <span class="text-accent text-sm">Read →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Link to all Medium articles -->
    <div class="reveal mt-8 text-center">
      <a
        href={site.social.medium}
        target="_blank"
        class="text-[#6e6e73] hover:text-accent text-sm transition-colors"
      >
        All articles on Medium →
      </a>
    </div>

  </div>
</section>
