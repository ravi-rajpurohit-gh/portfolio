---
/**
 * WHAT I BUILD — src/components/WhatIBuild.astro
 * ================================================
 * 2x2 grid of capability pillar cards.
 *
 * Content comes from src/data/site.ts → `pillars` array.
 * To add, remove, or reorder pillars, edit that array.
 *
 * Cards have a subtle hover effect (border brightens).
 * Icons are emoji for simplicity and cross-platform consistency.
 */

import { pillars } from '../data/site';
---

<section class="py-24 px-6 border-t border-[#2d2d2f]">
  <div class="max-w-6xl mx-auto">

    <p class="reveal text-accent text-sm font-medium uppercase tracking-widest mb-4">Capabilities</p>
    <h2 class="reveal text-4xl font-bold text-[#f5f5f7] mb-16">What I Build</h2>

    <div class="grid md:grid-cols-2 gap-6">
      {pillars.map((pillar, i) => (
        <div
          class="reveal glass-card rounded-2xl p-8 transition-colors duration-300"
          style={`animation-delay:${i * 0.1}s`}
        >
          <div class="mb-4 text-accent" set:html={pillar.icon}></div>
          <h3 class="text-[#f5f5f7] font-semibold text-lg mb-3">{pillar.title}</h3>
          <p class="text-[#6e6e73] text-sm leading-relaxed">{pillar.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
