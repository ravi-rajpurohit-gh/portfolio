---
---

<section class="min-h-screen flex flex-col justify-center px-6 pt-20">
  <div class="max-w-6xl mx-auto w-full">

    <p class="reveal text-accent text-sm font-medium uppercase tracking-widest mb-6">
      Data Infrastructure Engineer
    </p>

    <h1 class="reveal text-[clamp(3rem,8vw,6rem)] font-bold leading-[1.05] tracking-tight mb-6" style="animation-delay:0.1s">
      <span class="bg-gradient-to-br from-[#f5f5f7] to-[#6e6e73] bg-clip-text text-transparent">
        Ravi<br />Rajpurohit
      </span>
    </h1>

    <p class="reveal text-[#a1a1a6] text-xl md:text-2xl max-w-2xl leading-relaxed mb-10" style="animation-delay:0.2s">
      I build the pipelines, platforms, and analytics layers that turn raw data into decisions.
    </p>

    <div class="reveal flex flex-wrap gap-4" style="animation-delay:0.3s">
      <a
        href="#work"
        class="bg-accent hover:bg-[#0077ed] text-white font-medium px-6 py-3 rounded-full transition-colors duration-200"
      >
        View My Work
      </a>
      <a
        href="/resume.pdf"
        target="_blank"
        class="border border-[#2d2d2f] hover:border-[#6e6e73] text-[#f5f5f7] font-medium px-6 py-3 rounded-full transition-colors duration-200"
      >
        Download Resume
      </a>
      <a
        href="https://linkedin.com/in/ravi-rajpurohit"
        target="_blank"
        class="border border-[#2d2d2f] hover:border-[#6e6e73] text-[#a1a1a6] hover:text-[#f5f5f7] font-medium px-6 py-3 rounded-full transition-colors duration-200"
      >
        LinkedIn →
      </a>
    </div>

    <!-- Stat strip -->
    <div class="reveal mt-20 pt-10 border-t border-[#2d2d2f] grid grid-cols-2 md:grid-cols-4 gap-8" style="animation-delay:0.4s">
      {[
        { value: '5+', label: 'Years experience' },
        { value: '2B+', label: 'Events/month processed' },
        { value: '10M+', label: 'Users served' },
        { value: '15+', label: 'Data sources consolidated' },
      ].map(stat => (
        <div>
          <p class="text-3xl font-bold text-[#f5f5f7]">{stat.value}</p>
          <p class="text-sm text-[#6e6e73] mt-1">{stat.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
