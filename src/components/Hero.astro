---
/**
 * HERO — src/components/Hero.astro
 * ==================================
 * Full-viewport opening section with name, role, tagline, CTAs, and stats.
 *
 * Content comes from src/data/site.ts:
 *   - site.name      → gradient headline
 *   - site.role      → small label above headline
 *   - site.tagline   → paragraph below headline
 *   - site.resumeUrl → "Resume" button
 *   - site.stats     → 3-number strip at the bottom
 *
 * Animation: elements use the "reveal" class (defined in global.css) which
 * fades them in via IntersectionObserver (wired in Layout.astro's <script>).
 * animation-delay staggers each element slightly for a cascade effect.
 */

import { site } from '../data/site';
---

<section class="min-h-screen flex flex-col justify-center px-6 pt-20">
  <div class="max-w-6xl mx-auto w-full">

    <!-- Role label -->
    <p class="reveal text-accent text-sm font-medium uppercase tracking-widest mb-6">
      {site.role}
    </p>

    <!-- Name — gradient fades from white to gray for depth -->
    <h1
      class="reveal text-[clamp(3rem,8vw,6rem)] font-bold leading-[1.05] tracking-tight mb-6"
      style="animation-delay:0.1s"
    >
      <span class="bg-gradient-to-br from-[#f5f5f7] to-[#6e6e73] bg-clip-text text-transparent">
      Ravi<br />Rajpurohit
      </span>
    </h1>

    <!-- Tagline -->
    <p
      class="reveal text-[#a1a1a6] text-xl md:text-2xl max-w-2xl leading-relaxed mb-10"
      style="animation-delay:0.2s"
    >
      {site.tagline}
    </p>

    <!-- CTA buttons -->
    <div class="reveal flex flex-wrap gap-4" style="animation-delay:0.3s">
      <a
        href="#work"
        class="bg-accent hover:bg-[#0077ed] text-white font-medium px-6 py-3 rounded-full transition-colors duration-200"
      >
        View My Work
      </a>
      <a
        href={site.resumeUrl}
        target="_blank"
        class="border border-[#2d2d2f] hover:border-[#6e6e73] text-[#f5f5f7] font-medium px-6 py-3 rounded-full transition-colors duration-200"
      >
        Resume
      </a>
    </div>

    <!-- Stats strip — separated by a top border for visual weight -->
    <div
      class="reveal mt-20 pt-10 border-t border-[#2d2d2f] grid grid-cols-2 md:grid-cols-3 gap-8"
      style="animation-delay:0.4s"
    >
      {site.stats.map((stat) => (
        <div class="text-center">
          <p class="text-3xl font-bold text-[#f5f5f7]">{stat.value}</p>
          <p class="text-sm text-[#6e6e73] mt-1">{stat.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
