---
/**
 * CASE STUDY LAYOUT — src/layouts/CaseStudy.astro
 * =================================================
 * Layout for individual project case study pages.
 * Renders the page chrome (nav, header, footer) and loads Mermaid for diagrams.
 *
 * Props:
 *   title      — Project name (large H1)
 *   subtitle   — One-sentence description shown below the title
 *   tags       — Tech stack badges (string array)
 *   liveUrl    — Optional: link to live demo (shown as primary CTA button)
 *   githubUrl  — Optional: GitHub repo link
 *   mediumUrl  — Optional: Medium article link
 *
 * HOW TO ADD A NEW CASE STUDY:
 *   1. Create src/pages/projects/your-slug.astro
 *   2. Import and use this layout: `import CaseStudy from '../../layouts/CaseStudy.astro'`
 *   3. Pass the required props above
 *   4. Use the CSS classes defined in the <style is:global> block here:
 *        .cs-section  — wraps each content section (Overview, Architecture, etc.)
 *        .adr-card    — card for each Architectural Decision Record
 *        .mermaid     — container for Mermaid diagrams (pre tag with set:text)
 *
 * HOW MERMAID DIAGRAMS WORK:
 *   Mermaid@10 is loaded from CDN. Diagrams are defined as template literal
 *   strings in the page frontmatter and rendered via:
 *     <pre class="mermaid" set:text={diagramString}></pre>
 *   The `set:text` attribute is required — do NOT use curly braces directly
 *   inside the template as Astro treats them as JS expressions.
 *
 * Used by: src/pages/projects/*.astro
 */

import '../styles/global.css';
import ParticleBackground from '../components/ParticleBackground.astro';

interface Props {
  title: string;
  subtitle: string;
  tags: string[];
  liveUrl?: string;
  githubUrl?: string;
  mediumUrl?: string;
}

const { title, subtitle, tags, liveUrl, githubUrl, mediumUrl } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Ravi Rajpurohit</title>
    <!-- Mermaid@10 UMD build — provides a global `mermaid` object -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <script is:inline>
      /**
       * Initialize Mermaid with a dark theme matching the site palette.
       * Runs before page paint to avoid unstyled diagram flash.
       * To change the diagram appearance, edit themeVariables below.
       */
      mermaid.initialize({
        startOnLoad: true,
        theme: 'base',
        securityLevel: 'loose',
        flowchart: { useMaxWidth: false, nodeSpacing: 50, rankSpacing: 60 },
        er: { useMaxWidth: false },
        themeVariables: {
          background: '#1c1c1e',
          primaryColor: '#2997ff',
          primaryTextColor: '#f5f5f7',
          primaryBorderColor: '#2d2d2f',
          lineColor: '#6e6e73',
          secondaryColor: '#0a0a0a',
          tertiaryColor: '#1c1c1e',
          fontFamily: 'Inter, -apple-system, sans-serif',
          fontSize: '14px',
          nodeBorder: '#2d2d2f',
          clusterBkg: '#1c1c1e',
          titleColor: '#f5f5f7',
          edgeLabelBackground: '#1c1c1e',
          attributeBackgroundColorEven: '#1c1c1e',
          attributeBackgroundColorOdd: '#0a0a0a',
        },
      });
    </script>
  </head>
  <body>
    <ParticleBackground />
    <div style="position:relative;z-index:1;">

    <!-- Minimal sticky nav for case study pages -->
    <nav style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(0,0,0,0.45);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(255,255,255,0.08);">
      <div style="max-width:900px;margin:0 auto;padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;">
        <a href="/" style="color:#a1a1a6;font-size:0.875rem;text-decoration:none;">← Back</a>
        <a href="/" class="cs-nav-logo">ꝚꝚ</a>
      </div>
    </nav>

    <!-- Case study header -->
    <header style="padding:8rem 1.5rem 3rem;max-width:900px;margin:0 auto;">
      <p style="color:#2997ff;font-size:0.875rem;font-weight:500;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1rem;">
        Case Study
      </p>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:700;color:#f5f5f7;line-height:1.1;margin-bottom:1rem;">
        {title}
      </h1>
      <p style="font-size:1.125rem;color:#a1a1a6;max-width:640px;line-height:1.6;">
        {subtitle}
      </p>

      <!-- Tech stack badges -->
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1.5rem;">
        {tags.map((tag) => <span class="badge">{tag}</span>)}
      </div>

      <!-- CTA buttons — only rendered when the prop is provided -->
      <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-top:2rem;">
        {liveUrl && (
          <a href={liveUrl} target="_blank" style="display:inline-flex;align-items:center;gap:0.4rem;background:#2997ff;color:#fff;padding:0.5rem 1.25rem;border-radius:9999px;font-size:0.875rem;font-weight:500;text-decoration:none;">
            Live Demo →
          </a>
        )}
        {mediumUrl && (
          <a href={mediumUrl} target="_blank" style="display:inline-flex;align-items:center;gap:0.4rem;border:1px solid #2d2d2f;color:#f5f5f7;padding:0.5rem 1.25rem;border-radius:9999px;font-size:0.875rem;font-weight:500;text-decoration:none;">
            Read on Medium
          </a>
        )}
        {githubUrl && (
          <a href={githubUrl} target="_blank" style="display:inline-flex;align-items:center;gap:0.4rem;border:1px solid #2d2d2f;color:#f5f5f7;padding:0.5rem 1.25rem;border-radius:9999px;font-size:0.875rem;font-weight:500;text-decoration:none;">
            GitHub
          </a>
        )}
      </div>
    </header>

    <!-- Page body — provided by the individual case study page -->
    <main style="max-width:900px;margin:0 auto;padding:0 1.5rem 6rem;">
      <slot />
    </main>

    <footer style="border-top:1px solid #2d2d2f;padding:2rem 1.5rem;text-align:center;">
      <a href="/" style="color:#2997ff;font-size:0.875rem;text-decoration:none;">
        ← Back to all work
      </a>
    </footer>

    </div><!-- end z-index wrapper -->
  </body>
</html>

<style is:global>
  /**
   * Case study specific styles.
   * These are scoped to case study pages via the CaseStudy layout.
   *
   * .cs-section  — main content section wrapper (adds spacing + h2 styling)
   * .adr-card    — Architectural Decision Record card
   */

  /* RR logo link in the case study nav */
  .cs-nav-logo {
    color: #f5f5f7;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }

  .cs-nav-logo:hover {
    color: #2997ff;
  }

  /* ── Mermaid node polish ─────────────────────────────────────────── */

  /* Rounded corners on rectangular nodes */
  .mermaid .node rect {
    rx: 10px;
    ry: 10px;
  }

  /* More rounded on subgraph cluster backgrounds */
  .mermaid .cluster rect {
    rx: 14px;
    ry: 14px;
  }

  /* Center-align and breathe label text */
  .mermaid .nodeLabel {
    padding: 8px 16px !important;
    text-align: center !important;
    line-height: 1.5 !important;
  }

  /* Remove default paragraph margin inside labels */
  .mermaid .nodeLabel p {
    margin: 0 !important;
    line-height: 1.5 !important;
    text-align: center !important;
  }

  /* Edge label backgrounds */
  .mermaid .edgeLabel {
    padding: 2px 6px !important;
  }

  /* Mermaid diagram container — center SVG output and allow horizontal scroll */
  .mermaid {
    background: #1c1c1e;
    border-radius: 12px;
    padding: 2rem;
    overflow-x: auto;
    text-align: center;
  }

  .mermaid svg {
    display: inline-block;
    max-width: 100%;
    overflow: visible;
  }

  .cs-section {
    margin-bottom: 4rem;
  }

  .cs-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #f5f5f7;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #2d2d2f;
  }

  .cs-section p {
    color: #a1a1a6;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  /* ADR card: one per key engineering decision */
  .adr-card {
    background: rgba(255, 255, 255, 0.015);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    transition: border-color 0.2s;
  }

  .adr-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .adr-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #f5f5f7;
    margin: 0.4rem 0 0.6rem;
  }

  .adr-card p {
    color: #a1a1a6;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
  }

  /* Small label above the ADR question, e.g. "Decision #1 — Storage" */
  .adr-card .decision {
    display: inline-block;
    color: #2997ff;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
